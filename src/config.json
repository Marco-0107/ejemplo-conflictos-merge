{
  "aplicacion": {
    "nombre": "Calculadora Avanzada Pro",
    "version": "2.0.0",
    "descripcion": "Calculadora profesional con funciones matemáticas avanzadas"
  },
  "configuracion": {
    "debug": true,
    "puerto": 9090,
    "host": "0.0.0.0",
    "timeout": 60,
    "max_operaciones": 1000
  },
  "base_datos": {
    "tipo": "sqlite",
    "archivo": "demo.db",
    "auto_backup": true
  },
  "logging": {
    "nivel": "INFO",
    "archivo": "app.log",
    "formato": "%(asctime)s - %(levelname)s - %(message)s"
  },
  "caracteristicas": {
    "cache_habilitado": true,
    "compresion": false,
    "ssl": false
  }
}
